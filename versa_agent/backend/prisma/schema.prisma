// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid(name: "uuid-ossp")]
}

// User model
model User {
  id        String   @id @default(uuid_generate_v4())
  username  String   @unique
  email     String   @unique
  createdAt DateTime @default(now())

  workflows  Workflow[]
  agents     Agent[]
  llmUsage   LlmUsage[]

  @@map("users")
}

// Workflow model
model Workflow {
  id          String   @id @default(uuid_generate_v4())
  userId      String
  name        String
  description String?
  mode        WorkflowMode
  config      Json
  status      WorkflowStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps  WorkflowStep[]

  @@map("workflows")
}

// Workflow step model
model WorkflowStep {
  id           String          @id @default(uuid_generate_v4())
  workflowId   String
  sequence     Int
  agentName    String
  task         String
  status       StepStatus      @default(PENDING)
  input        Json?
  output       Json?
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  requiresConfirm Boolean     @default(false)
  confirmed    Boolean?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_steps")
}

// Agent model
model Agent {
  id           String   @id @default(uuid_generate_v4())
  userId       String?
  name         String   @unique
  role         String
  systemPrompt String?
  llmProvider  String
  llmModel     String
  mcpTools     String[]
  capabilities Json
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("agents")
}

// LLM Usage tracking
model LlmUsage {
  id              String   @id @default(uuid_generate_v4())
  userId          String?
  provider        String
  model           String
  promptTokens    Int
  completionTokens Int
  totalTokens     Int
  costUsd         Decimal  @db.Decimal(10, 4)
  timestamp       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("llm_usage")
}

// Enums
enum WorkflowMode {
  AUTO
  SEMI
  TEMPLATE
}

enum WorkflowStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum StepStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}
